/*#
#define CTIMEUTILS_IMPLEMENTATION
#include "ctime_utils.h"
#define TYPE "ll"
// type name
char *ll(const char *T) {
	return format(TYPE"_%s*", T);
}
// methods
char *ll_new(const char *T) {
	return format(TYPE"_%s_new()", T);
}
char *ll_sum(const char *T) {
	return format(TYPE"_%s_sum", T);
}
char *ll_push(const char *T) {
	return format(TYPE"_%s_push(", T);
}
// required traits
char *ll_zero_trait(const char *T) {
	return format(TYPE"_%s_zero", T);
}
char *ll_add_trait(const char *T) {
	return format(TYPE"_%s_add", T);
}
char *ll_format_trait(const char *T) {
	return format(TYPE"_%s_format", T);
}
// implementation
char *ll_template(const char *T) {
	return format(
"#include <stdlib.h>\n"
"typedef struct node_%s {\n"
"	struct node_%s *next;\n"
"	%s data;\n"
"} node_%s;\n"
"typedef struct ll_%s {\n"
"	struct node_%s *head;\n"
"	int len;\n"
"} ll_%s;\n"
"ll_%s *ll_%s_new() {\n"
"	ll_%s *L = malloc(sizeof(*L));\n"
"	*L = (ll_%s) { NULL, 0 };\n"
"	return L;\n"
"}\n"
"void ll_%s_push(ll_%s *L, %s v) {\n"
"	node_%s *N = malloc(sizeof(*N));\n"
"	*N = (node_%s) {\n"
"		.next = L->head,\n"
"		.data = v\n"
"	};\n"
"	L->head = N;\n"
"	L->len++;\n"
"}\n"
"%s ll_%s_sum_inner(ll_%s *L) {\n"
"	%s acc = ll_%s_zero();\n"
"	node_%s *cur = L->head;\n"
"	while (cur) {\n"
"		acc = ll_%s_add(acc, cur->data);\n"
"		cur = cur->next;\n"
"	}\n"
"	return acc;\n"
"}\n"
"char *ll_%s_sum(ll_%s *L) {\n"
"	%s sum = ll_%s_sum_inner(L);\n"
"	return ll_%s_format(sum);\n"
"}\n"
	,
	T, T, T, T, T, T, T,
	T, T, T, T, T, T,
	T, T, T, T, T, T,
	T, T, T, T, T, T,
	T, T, T, T, T);
// TODO: a higher level of abstraction for these Ts
// nesting /*$ ... $* / inside these could work
// but is nontrivial to implement
}
#*/
#define CTIMEUTILS_IMPLEMENTATION
#include "ctime_utils.h"
#include <stdio.h>

int /*$ ll_zero_trait("int") $*/()
	{ return 0; }
int /*$ ll_add_trait("int") $*/(int a, int b)
	{ return a + b; }
char* /*$ ll_format_trait("int") $*/(int k)
	{ return format("%d", k); }
/*$ ll_template("int") $*/

float /*$ ll_zero_trait("float") $*/()
	{ return 10.0; } // trait misuse!
float /*$ ll_add_trait("float") $*/(float x, float y)
	{ return x + y; }
char* /*$ ll_format_trait("float") $*/(float x)
	{ return format("%f", x); }
/*$ ll_template("float") $*/

#include <string.h>
typedef struct cstr {
	char* s;
} cstr;
cstr /*$ ll_zero_trait("cstr") $*/()
	{ return (cstr) { .s = "" }; }
cstr /*$ ll_add_trait("cstr") $*/(cstr s1, const cstr s2)
	{
		char *s = malloc(1);
		*s = '\0';
		strcat(s, s1.s);
		strcat(s, s2.s);
		return (cstr) { .s=s };
	}
char* /*$ ll_format_trait("cstr") $*/(cstr s)
	{ return s.s; }
/*$ ll_template("cstr") $*/

int main() {
	/*$ ll("int") $*/ intlist = /*$ ll_new("int") $*/;
	/*$ ll_push("int") $*/intlist, 6);
	/*$ ll_push("int") $*/intlist, 7);
	printf("%s\n", /*$ ll_sum("int") $*/(intlist) );
	/*$ ll("float") $*/ floatlist = /*$ ll_new("float") $*/;
	/*$ ll_push("float") $*/floatlist, 6.0);
	/*$ ll_push("float") $*/floatlist, 7.0);
	printf("%s\n", /*$ ll_sum("float") $*/(floatlist) );
	/*$ ll("cstr") $*/ strlist = /*$ ll_new("cstr") $*/;
	/*$ ll_push("cstr") $*/strlist, (cstr) { .s="t" });
	/*$ ll_push("cstr") $*/strlist, (cstr) { .s="r" });
	/*$ ll_push("cstr") $*/strlist, (cstr) { .s="d" });
	printf("%s\n", /*$ ll_sum("cstr") $*/(strlist) );
	return 0;
}

